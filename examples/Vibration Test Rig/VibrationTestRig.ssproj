                    "title": "Vibration (RMS)",
                    "transformCode": "-- Rolling RMS over last N samples\n-- Faster hot-path than JS for high-rate telemetry.\n\nlocal N = 1024\nlocal history = {}\nfor i = 1, N do history[i] = 0 end\n\nlocal idx = 1\nlocal count = 0\nlocal sumSq = 0\n\nfunction transform(value)\n  local v = tonumber(value) or 0\n  local sq = v * v\n\n  sumSq = sumSq - history[idx] + sq\n  history[idx] = sq\n\n  idx = idx + 1\n  if idx > N then idx = 1 end\n\n  if count < N then count = count + 1 end\n  if sumSq < 0 then sumSq = 0 end\n\n  return math.sqrt(sumSq / count)\nend\n",
                    "transformLanguage": 1,
