                {
                    "datasetId": 1,
                    "displayFormat": "0d",
                    "displayTickCount": 5,
                    "fft": false,
                    "fftMax": 6,
                    "fftMin": -60,
                    "fftSamples": 256,
                    "fftSamplingRate": 1000,
                    "graph": true,
                    "groupId": 1,
                    "index": 4,
                    "led": false,
                    "ledHigh": 1,
                    "log": false,
                    "numericValue": 0,
                    "plotMax": 6,
                    "plotMin": -60,
                    "title": "Mic R",
                    "uniqueId": 10001,
                    "units": "dB",
