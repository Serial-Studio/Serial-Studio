            "painterCode": "// Live system schematic for the Vibration Test Rig, themed.\n// Three stages, left to right: motor -> bracket + accelerometer -> mics.\n// Each stage is bound to live datasets:\n//\n//   datasets[0] = vibration   (g)\n//   datasets[1] = motor RPM\n//   datasets[2] = mic L       (dB FS)\n//   datasets[3] = mic R       (dB FS)\n\nconst TWO_PI = Math.PI * 2;\n\n// All colors derive from the active theme so the schematic follows\n// light/dark theme switches automatically.\nfunction palette() {\n  return theme.widget_colors || [theme.widget_highlight];\n}\n\nfunction pickColor(i) {\n  const p = palette();\n  return p[i % p.length];\n}\n\nfunction mixHex(a, b, t) {\n  const pa = parseInt(a.slice(1), 16);\n  const pb = parseInt(b.slice(1), 16);\n  const ar = (pa >> 16) & 0xff, ag = (pa >> 8) & 0xff, ab = pa & 0xff;\n  const br = (pb >> 16) & 0xff, bg = (pb >> 8) & 0xff, bb = pb & 0xff;\n  const r = Math.round(ar + (br - ar) * t);\n  const g = Math.round(ag + (bg - ag) * t);\n  const b2 = Math.round(ab + (bb - ab) * t);\n  return \"#\" + ((1 << 24) | (r << 16) | (g << 8) | b2).toString(16).slice(1);\n}\n\n// State\nlet rotorAngle = 0;\nlet lastTs     = 0;\nlet chase      = 0;\nlet tracePhase = 0;\n\nfunction db_to_intensity(db) {\n  return Math.max(0, Math.min(1, (db + 60) / 66));\n}\n\nfunction rpm_to_rad_per_s(rpm) {\n  return TWO_PI * rpm / 60.0;\n}\n\nfunction onFrame() {\n  const now = Date.now();\n  const dt  = lastTs > 0 ? Math.max(0, (now - lastTs) * 1e-3) : 0;\n  lastTs    = now;\n\n  if (datasets.length < 4) return;\n\n  // Spin rotor at the actual motor RPM, visually scaled so it doesn't\n  // strobe into invisibility.\n  const rpm = datasets[1].value;\n  rotorAngle = (rotorAngle + rpm_to_rad_per_s(rpm) * dt / 30) % TWO_PI;\n\n  // Trace scroll uses its own phase so the bracket itself stays still.\n  tracePhase = (tracePhase + dt * 12 * TWO_PI) % TWO_PI;\n\n  // Packet chase speed scales with audio activity.\n  const micAvg = (db_to_intensity(datasets[2].value) +\n                  db_to_intensity(datasets[3].value)) * 0.5;\n  const baseSpeed = 0.6;\n  const chaseSpeed = baseSpeed + micAvg * 1.4;\n  chase = (chase + dt * chaseSpeed) % 1;\n}\n\nfunction draw_card(ctx, x, y, w, h, label) {\n  // Soft drop shadow.\n  ctx.fillStyle = mixHex(theme.widget_border, theme.widget_base, 0.4);\n  ctx.fillRect(x + 2, y + 3, w, h);\n\n  ctx.fillStyle = theme.alternate_base || theme.widget_base;\n  ctx.fillRect(x, y, w, h);\n  ctx.strokeStyle = theme.widget_border;\n  ctx.lineWidth = 1;\n  ctx.strokeRect(x + 0.5, y + 0.5, w - 1, h - 1);\n\n  // Label strip at the top.\n  ctx.fillStyle = mixHex(theme.alternate_base || theme.widget_base, theme.widget_text, 0.04);\n  ctx.fillRect(x + 1, y + 1, w - 2, 18);\n  ctx.fillStyle = theme.widget_border;\n  ctx.fillRect(x + 1, y + 19, w - 2, 1);\n\n  ctx.fillStyle = theme.widget_text;\n  ctx.font = \"bold 10px sans-serif\";\n  ctx.textAlign = \"start\";\n  ctx.fillText(label, x + 8, y + 13);\n}\n\nfunction draw_motor(ctx, cx, cy, radius, rpm) {\n  const motor_body = mixHex(theme.widget_text, theme.widget_base, 0.55);\n  const motor_cap  = mixHex(theme.widget_text, theme.widget_base, 0.35);\n  const rotor      = pickColor(2);\n  const rotor_hub  = theme.widget_text;\n  const bolt       = theme.widget_border;\n\n  // Motor body (cylinder seen from the end).\n  ctx.fillStyle = motor_body;\n  ctx.beginPath();\n  ctx.moveTo(cx + radius, cy);\n  ctx.arc(cx, cy, radius, 0, TWO_PI);\n  ctx.fill();\n\n  // Outer ring.\n  ctx.strokeStyle = motor_cap;\n  ctx.lineWidth = 3;\n  ctx.beginPath();\n  ctx.moveTo(cx + radius - 1, cy);\n  ctx.arc(cx, cy, radius - 1, 0, TWO_PI);\n  ctx.stroke();\n\n  // Bolt heads around the rim.\n  for (let i = 0; i < 8; ++i) {\n    const a = (i / 8) * TWO_PI;\n    const bx = cx + Math.cos(a) * (radius - 6);\n    const by = cy + Math.sin(a) * (radius - 6);\n    ctx.fillStyle = bolt;\n    ctx.beginPath();\n    ctx.moveTo(bx + 2, by);\n    ctx.arc(bx, by, 2, 0, TWO_PI);\n    ctx.fill();\n  }\n\n  // Spinning rotor (3-spoke).\n  ctx.save();\n  ctx.translate(cx, cy);\n  ctx.rotate(rotorAngle);\n  ctx.fillStyle = rotor;\n  for (let i = 0; i < 3; ++i) {\n    ctx.save();\n    ctx.rotate((i / 3) * TWO_PI);\n    ctx.fillRect(-3, -radius * 0.55, 6, radius * 0.55);\n    ctx.restore();\n  }\n  // Hub\n  ctx.fillStyle = rotor_hub;\n  ctx.beginPath();\n  ctx.moveTo(6, 0);\n  ctx.arc(0, 0, 6, 0, TWO_PI);\n  ctx.fill();\n  ctx.restore();\n\n  // RPM caption beneath -- never moves.\n  ctx.fillStyle = theme.widget_text;\n  ctx.font = \"bold 13px sans-serif\";\n  ctx.textAlign = \"center\";\n  ctx.fillText(rpm.toFixed(0), cx, cy + radius + 18);\n  ctx.fillStyle = theme.placeholder_text;\n  ctx.font = \"9px sans-serif\";\n  ctx.fillText(\"RPM\", cx, cy + radius + 30);\n}\n\nfunction draw_bracket(ctx, cx, cy, vib) {\n  const bracket   = theme.widget_border;\n  const sensor    = pickColor(5);\n  const sensor_dk = mixHex(sensor, theme.widget_text, 0.45);\n\n  // L-bracket\n  ctx.fillStyle = bracket;\n  ctx.fillRect(cx - 30, cy - 2, 60, 6);\n  ctx.fillRect(cx - 30, cy - 28, 6, 30);\n  ctx.strokeStyle = mixHex(bracket, theme.widget_text, 0.35);\n  ctx.lineWidth = 1;\n  ctx.strokeRect(cx - 30 + 0.5, cy - 2 + 0.5, 60, 6);\n  ctx.strokeRect(cx - 30 + 0.5, cy - 28 + 0.5, 6, 30);\n\n  // Mounted accelerometer (small PCB).\n  ctx.fillStyle = sensor;\n  ctx.fillRect(cx - 12, cy - 22, 24, 16);\n  ctx.strokeStyle = sensor_dk;\n  ctx.lineWidth = 1;\n  ctx.strokeRect(cx - 12 + 0.5, cy - 22 + 0.5, 24, 16);\n  // chip on top\n  ctx.fillStyle = theme.widget_text;\n  ctx.fillRect(cx - 5, cy - 18, 10, 8);\n  // led\n  ctx.fillStyle = pickColor(2);\n  ctx.beginPath();\n  ctx.moveTo(cx + 8, cy - 19);\n  ctx.arc(cx + 7, cy - 19, 1.5, 0, TWO_PI);\n  ctx.fill();\n\n  // Mini vibration trace beneath the bracket.\n  draw_vibration_trace(ctx, cx - 38, cy + 16, 76, 18, vib, sensor_dk);\n\n  // Caption -- stationary text.\n  ctx.fillStyle = theme.widget_text;\n  ctx.font = \"bold 13px sans-serif\";\n  ctx.textAlign = \"center\";\n  ctx.fillText(vib.toFixed(2) + \" g\", cx, cy + 50);\n  ctx.fillStyle = theme.placeholder_text;\n  ctx.font = \"9px sans-serif\";\n  ctx.fillText(\"ACCELEROMETER\", cx, cy + 62);\n}\n\n// Tiny scrolling vibration sparkline (cosmetic -- driven by trace phase\n// so it reads as motion even when vib is steady).\nconst traceBuf = [];\nconst TRACE_N = 64;\nfunction draw_vibration_trace(ctx, x, y, w, h, vib, traceColor) {\n  const sample = Math.sin(tracePhase * 1.7) * Math.min(3, Math.abs(vib));\n  traceBuf.push(sample);\n  if (traceBuf.length > TRACE_N) traceBuf.shift();\n\n  ctx.fillStyle = mixHex(theme.widget_base, theme.widget_border, 0.25);\n  ctx.fillRect(x, y, w, h);\n  ctx.strokeStyle = theme.widget_border;\n  ctx.lineWidth = 1;\n  ctx.strokeRect(x + 0.5, y + 0.5, w - 1, h - 1);\n\n  ctx.fillStyle = theme.widget_border;\n  ctx.fillRect(x + 2, y + h * 0.5, w - 4, 1);\n\n  if (traceBuf.length < 2) return;\n  ctx.strokeStyle = traceColor;\n  ctx.lineWidth = 1.5;\n  ctx.beginPath();\n  for (let i = 0; i < traceBuf.length; ++i) {\n    const px = x + 2 + (i / (TRACE_N - 1)) * (w - 4);\n    const py = y + h * 0.5 - (traceBuf[i] / 3) * (h * 0.42);\n    if (i === 0) ctx.moveTo(px, py);\n    else         ctx.lineTo(px, py);\n  }\n  ctx.stroke();\n}\n\nfunction draw_mic(ctx, cx, cy, label, db, maxR) {\n  const mic_body  = theme.widget_text;\n  const mic_ring  = pickColor(2);\n  const mic_ring2 = theme.alarm;\n  const mic_halo  = mixHex(mic_ring, theme.widget_base, 0.55);\n  const grille    = mixHex(theme.widget_text, theme.widget_base, 0.45);\n  const stand     = mixHex(theme.widget_text, theme.widget_base, 0.35);\n\n  const intensity = db_to_intensity(db);\n  const cap = Math.max(8, maxR);\n  const ringR = Math.min(cap, 14 + intensity * 4);\n  const ringColor = (db > 0) ? mic_ring2 : mic_ring;\n\n  // Halo\n  ctx.strokeStyle = mic_halo;\n  ctx.lineWidth = 3;\n  ctx.beginPath();\n  ctx.moveTo(cx + ringR + 2, cy);\n  ctx.arc(cx, cy, ringR + 2, 0, TWO_PI);\n  ctx.stroke();\n\n  ctx.strokeStyle = ringColor;\n  ctx.lineWidth = 2;\n  ctx.beginPath();\n  ctx.moveTo(cx + ringR, cy);\n  ctx.arc(cx, cy, ringR, 0, TWO_PI);\n  ctx.stroke();\n\n  // Mic body (capsule)\n  ctx.fillStyle = mic_body;\n  ctx.fillRect(cx - 7, cy - 14, 14, 24);\n  ctx.beginPath();\n  ctx.moveTo(cx + 7, cy - 14);\n  ctx.arc(cx, cy - 14, 7, 0, Math.PI, true);\n  ctx.fill();\n  ctx.beginPath();\n  ctx.moveTo(cx + 7, cy + 10);\n  ctx.arc(cx, cy + 10, 7, 0, Math.PI);\n  ctx.fill();\n\n  // Grille lines\n  ctx.strokeStyle = grille;\n  ctx.lineWidth = 1;\n  for (let i = -2; i <= 2; ++i) {\n    ctx.beginPath();\n    ctx.moveTo(cx - 6, cy + i * 4);\n    ctx.lineTo(cx + 6, cy + i * 4);\n    ctx.stroke();\n  }\n\n  // Stand\n  ctx.fillStyle = stand;\n  ctx.fillRect(cx - 1, cy + 16, 2, 10);\n  ctx.fillRect(cx - 8, cy + 26, 16, 3);\n\n  // Label & dB readout -- stationary text.\n  ctx.fillStyle = theme.widget_text;\n  ctx.font = \"bold 11px sans-serif\";\n  ctx.textAlign = \"center\";\n  ctx.fillText(label, cx, cy + 44);\n  ctx.fillStyle = theme.placeholder_text;\n  ctx.font = \"10px sans-serif\";\n  ctx.fillText(db.toFixed(1) + \" dB\", cx, cy + 56);\n}\n\nfunction draw_wire(ctx, x0, y0, x1, y1, hot) {\n  const wire_off = theme.widget_border;\n  const wire_on  = theme.widget_highlight;\n  ctx.strokeStyle = hot ? wire_on : wire_off;\n  ctx.lineWidth = hot ? 2 : 1.5;\n  ctx.beginPath();\n  ctx.moveTo(x0, y0);\n  ctx.lineTo(x1, y1);\n  ctx.stroke();\n\n  const dx = x1 - x0, dy = y1 - y0;\n  for (let i = 0; i < 3; ++i) {\n    const t = (chase + i / 3) % 1;\n    const px = x0 + dx * t;\n    const py = y0 + dy * t;\n    ctx.fillStyle = hot ? wire_on : wire_off;\n    ctx.beginPath();\n    ctx.moveTo(px + 2.5, py);\n    ctx.arc(px, py, 2.5, 0, TWO_PI);\n    ctx.fill();\n  }\n}\n\nfunction paint(ctx, w, h) {\n  ctx.fillStyle = theme.widget_base;\n  ctx.fillRect(0, 0, w, h);\n\n  if (datasets.length < 4) {\n    ctx.fillStyle = theme.placeholder_text;\n    ctx.font = \"12px sans-serif\";\n    ctx.textAlign = \"center\";\n    ctx.fillText(\"Waiting for vibration, RPM, mic L, mic R...\", w/2, h/2);\n    return;\n  }\n\n  // Header\n  ctx.fillStyle = theme.widget_text;\n  ctx.font = \"bold 12px sans-serif\";\n  ctx.textAlign = \"start\";\n  ctx.fillText(\"SYSTEM  SCHEMATIC\", 16, 20);\n  ctx.fillStyle = theme.placeholder_text;\n  ctx.font = \"10px sans-serif\";\n  ctx.textAlign = \"end\";\n  ctx.fillText(\"live data flow\", w - 16, 20);\n\n  ctx.fillStyle = theme.widget_border;\n  ctx.fillRect(16, 28, w - 32, 1);\n\n  // Layout: 3 stages distributed horizontally.\n  const top    = 44;\n  const bottom = h - 16;\n  const midY   = (top + bottom) / 2;\n\n  const colW   = (w - 40) / 3;\n  const cx0    = 20 + colW * 0.5;\n  const cx1    = 20 + colW * 1.5;\n  const cx2    = 20 + colW * 2.5;\n\n  const cardW = colW - 20;\n  const cardH = bottom - top;\n  draw_card(ctx, cx0 - cardW/2, top, cardW, cardH, \"MOTOR\");\n  draw_card(ctx, cx1 - cardW/2, top, cardW, cardH, \"BRACKET + ACCEL\");\n  draw_card(ctx, cx2 - cardW/2, top, cardW, cardH, \"ENCLOSURE MICS\");\n\n  // Wires connecting the cards' edges.\n  const wireY = midY;\n  draw_wire(ctx, cx0 + cardW/2, wireY, cx1 - cardW/2, wireY, true);\n  draw_wire(ctx, cx1 + cardW/2, wireY, cx2 - cardW/2, wireY, true);\n\n  // Stage 0 -- Motor\n  const motorR = Math.min(cardW, cardH) * 0.28;\n  draw_motor(ctx, cx0, midY - 8, motorR, datasets[1].value);\n\n  // Stage 1 -- Bracket + accelerometer (stationary)\n  draw_bracket(ctx, cx1, midY - 14, datasets[0].value);\n\n  // Stage 2 -- Two mics, side by side. Budget: each mic gets half the\n  // card width minus a small inner gap; the ring radius (with a 4 px halo\n  // margin) must fit inside that half-cell so it cannot overflow the card.\n  const innerW = cardW - 16;\n  const halfCell = innerW / 2;\n  const maxRingR = Math.max(8, halfCell - 6);\n  const micGap = Math.min(28, halfCell * 0.5);\n  draw_mic(ctx, cx2 - micGap, midY - 4, \"L\", datasets[2].value, maxRingR);\n  draw_mic(ctx, cx2 + micGap, midY - 4, \"R\", datasets[3].value, maxRingR);\n}\n",
            "title": "System Schematic",
            "uniqueId": 40008,
            "widget": "painter"
        }
