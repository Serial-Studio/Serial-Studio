            "frameParserCode": "/**\n * Frame parser that extracts latitude and longitude from ISS position JSON.\n */\nfunction parse(frame) {\n  if (frame.length === 0) {\n    return [];\n  }\n  \n  try {\n    var data = JSON.parse(frame + \"}\");\n    return [\n      data.latitude,\n      data.longitude\n    ];\n  } catch (e) {\n    console.warn(\"Failed to parse JSON: \" + e);\n    return [];\n  }\n}\n",
