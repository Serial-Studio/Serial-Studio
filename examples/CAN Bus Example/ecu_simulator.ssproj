    "sources": [
        {
            "busType": 5,
            "checksum": "",
            "checksumAlgorithm": "",
            "decoder": 3,
            "decoderMethod": 3,
            "frameDetection": 2,
            "frameEnd": "",
            "frameParserCode": "--\n-- CAN DBC Frame Parser\n--\n-- Auto-generated from: ecu_simulator.dbc\n--\n-- Total signals: 42\n-- Total messages: 14\n--\n-- Frame format:\n--   Byte 1-2: CAN ID (big-endian, 16-bit)\n--   Byte 3:   Data Length Code (DLC)\n--   Byte 4+:  CAN data payload\n--\n-- Multiplex notes:\n--   Selector signals are listed as [selector] and extracted first.\n--   Muxed signals are listed as [mux N] and only updated when the\n--   selector raw value equals N. Extended multiplexing is not supported.\n--\n\nlocal values = {}\nfor i = 1, 42 do values[i] = 0 end\n\nlocal function extractSignal(data, startBit, length, isBigEndian, isSigned)\n  local value = 0\n\n  if isBigEndian then\n    local startByte = startBit // 8\n    local numBytes = (length + 7) // 8\n\n    -- Byte-aligned fast path\n    if startBit % 8 == 0 and length % 8 == 0 then\n      for i = 0, numBytes - 1 do\n        if startByte + i + 1 <= #data then\n          value = (value << 8) | data[startByte + i + 1]\n        end\n      end\n    else\n      -- Non-byte-aligned: bit-by-bit extraction\n      for bit = 0, length - 1 do\n        local bitPos = startBit + bit\n        local byteIdx = bitPos // 8 + 1\n        local bitIdx = 7 - (bitPos % 8)\n        if byteIdx <= #data then\n          value = (value << 1) | ((data[byteIdx] >> bitIdx) & 1)\n        end\n      end\n    end\n  else\n    -- Intel (little-endian)\n    local startByte = startBit // 8\n    local startBitInByte = startBit % 8\n    local bitsRead = 0\n\n    local i = startByte\n    while i + 1 <= #data and bitsRead < length do\n      local bitsInThisByte\n      if i == startByte then\n        bitsInThisByte = math.min(8 - startBitInByte, length - bitsRead)\n      else\n        bitsInThisByte = math.min(8, length - bitsRead)\n      end\n      local shift = (i == startByte) and startBitInByte or 0\n      local mask = ((1 << bitsInThisByte) - 1) << shift\n      local bits = (data[i + 1] & mask) >> shift\n      value = value | (bits << bitsRead)\n      bitsRead = bitsRead + bitsInThisByte\n      i = i + 1\n    end\n  end\n\n  -- Apply signed conversion\n  if isSigned and (value & (1 << (length - 1))) ~= 0 then\n    value = value - (1 << length)\n  end\n\n  return value\nend\n\n--\n-- Decodes CAN message: ENGINE_RPM_SPEED (ID: 0x100)\n--\n-- Signals (2):\n--   [1] EngineRPM (rpm)\n--   [2] VehicleSpeed (km/h)\n--\nlocal function decode_100(data)\n  -- EngineRPM [rpm]\n  local raw_EngineRPM = extractSignal(data, 0, 16, false, false)\n  local value_EngineRPM = (raw_EngineRPM * 0.25) + 0\n  values[1] = value_EngineRPM\n\n  -- VehicleSpeed [km/h]\n  local raw_VehicleSpeed = extractSignal(data, 16, 16, false, false)\n  local value_VehicleSpeed = (raw_VehicleSpeed * 0.01) + 0\n  values[2] = value_VehicleSpeed\nend\n\n--\n-- Decodes CAN message: ENGINE_TEMP_LOAD (ID: 0x101)\n--\n-- Signals (3):\n--   [3] EngineLoad (%)\n--   [4] CoolantTemp (degC)\n--   [5] IntakeTemp (degC)\n--\nlocal function decode_101(data)\n  -- EngineLoad [%]\n  local raw_EngineLoad = extractSignal(data, 16, 8, false, false)\n  local value_EngineLoad = (raw_EngineLoad * 1) + 0\n  values[3] = value_EngineLoad\n\n  -- CoolantTemp [degC]\n  local raw_CoolantTemp = extractSignal(data, 0, 8, false, false)\n  local value_CoolantTemp = (raw_CoolantTemp * 1) + -40\n  values[4] = value_CoolantTemp\n\n  -- IntakeTemp [degC]\n  local raw_IntakeTemp = extractSignal(data, 8, 8, false, false)\n  local value_IntakeTemp = (raw_IntakeTemp * 1) + -40\n  values[5] = value_IntakeTemp\nend\n\n--\n-- Decodes CAN message: ENGINE_THROTTLE (ID: 0x102)\n--\n-- Signals (2):\n--   [6] FuelPressure (kPa)\n--   [7] ThrottlePosition (%)\n--\nlocal function decode_102(data)\n  -- FuelPressure [kPa]\n  local raw_FuelPressure = extractSignal(data, 8, 16, false, false)\n  local value_FuelPressure = (raw_FuelPressure * 1) + 0\n  values[6] = value_FuelPressure\n\n  -- ThrottlePosition [%]\n  local raw_ThrottlePosition = extractSignal(data, 0, 8, false, false)\n  local value_ThrottlePosition = (raw_ThrottlePosition * 0.392157) + 0\n  values[7] = value_ThrottlePosition\nend\n\n--\n-- Decodes CAN message: TRANSMISSION_GEAR (ID: 0x200)\n--\n-- Signals (3):\n--   [8] CurrentGear (no unit)\n--   [9] TorqueConverterSlip (%)\n--   [10] TransmissionTemp (degC)\n--\nlocal function decode_200(data)\n  -- CurrentGear\n  local raw_CurrentGear = extractSignal(data, 0, 8, false, false)\n  local value_CurrentGear = (raw_CurrentGear * 1) + 0\n  values[8] = value_CurrentGear\n\n  -- TorqueConverterSlip [%]\n  local raw_TorqueConverterSlip = extractSignal(data, 16, 8, false, false)\n  local value_TorqueConverterSlip = (raw_TorqueConverterSlip * 1) + 0\n  values[9] = value_TorqueConverterSlip\n\n  -- TransmissionTemp [degC]\n  local raw_TransmissionTemp = extractSignal(data, 8, 8, false, false)\n  local value_TransmissionTemp = (raw_TransmissionTemp * 1) + -40\n  values[10] = value_TransmissionTemp\nend\n\n--\n-- Decodes CAN message: BCM_LIGHTS (ID: 0x300)\n--\n-- Signals (5):\n--   [11] TurnSignalLeft (no unit)\n--   [12] HazardLights (no unit)\n--   [13] TurnSignalRight (no unit)\n--   [14] Headlights (no unit)\n--   [15] HighBeams (no unit)\n--\nlocal function decode_300(data)\n  -- TurnSignalLeft\n  local raw_TurnSignalLeft = extractSignal(data, 2, 1, false, false)\n  local value_TurnSignalLeft = (raw_TurnSignalLeft * 1) + 0\n  values[11] = value_TurnSignalLeft\n\n  -- HazardLights\n  local raw_HazardLights = extractSignal(data, 4, 1, false, false)\n  local value_HazardLights = (raw_HazardLights * 1) + 0\n  values[12] = value_HazardLights\n\n  -- TurnSignalRight\n  local raw_TurnSignalRight = extractSignal(data, 3, 1, false, false)\n  local value_TurnSignalRight = (raw_TurnSignalRight * 1) + 0\n  values[13] = value_TurnSignalRight\n\n  -- Headlights\n  local raw_Headlights = extractSignal(data, 0, 1, false, false)\n  local value_Headlights = (raw_Headlights * 1) + 0\n  values[14] = value_Headlights\n\n  -- HighBeams\n  local raw_HighBeams = extractSignal(data, 1, 1, false, false)\n  local value_HighBeams = (raw_HighBeams * 1) + 0\n  values[15] = value_HighBeams\nend\n\n--\n-- Decodes CAN message: BCM_DOORS (ID: 0x301)\n--\n-- Signals (5):\n--   [16] DoorFrontRight (no unit)\n--   [17] DoorFrontLeft (no unit)\n--   [18] DoorRearLeft (no unit)\n--   [19] DoorRearRight (no unit)\n--   [20] Trunk (no unit)\n--\nlocal function decode_301(data)\n  -- DoorFrontRight\n  local raw_DoorFrontRight = extractSignal(data, 1, 1, false, false)\n  local value_DoorFrontRight = (raw_DoorFrontRight * 1) + 0\n  values[16] = value_DoorFrontRight\n\n  -- DoorFrontLeft\n  local raw_DoorFrontLeft = extractSignal(data, 0, 1, false, false)\n  local value_DoorFrontLeft = (raw_DoorFrontLeft * 1) + 0\n  values[17] = value_DoorFrontLeft\n\n  -- DoorRearLeft\n  local raw_DoorRearLeft = extractSignal(data, 2, 1, false, false)\n  local value_DoorRearLeft = (raw_DoorRearLeft * 1) + 0\n  values[18] = value_DoorRearLeft\n\n  -- DoorRearRight\n  local raw_DoorRearRight = extractSignal(data, 3, 1, false, false)\n  local value_DoorRearRight = (raw_DoorRearRight * 1) + 0\n  values[19] = value_DoorRearRight\n\n  -- Trunk\n  local raw_Trunk = extractSignal(data, 4, 1, false, false)\n  local value_Trunk = (raw_Trunk * 1) + 0\n  values[20] = value_Trunk\nend\n\n--\n-- Decodes CAN message: BMS_VOLTAGE_CURRENT (ID: 0x400)\n--\n-- Signals (2):\n--   [21] PackCurrent (A)\n--   [22] PackVoltage (V)\n--\nlocal function decode_400(data)\n  -- PackCurrent [A]\n  local raw_PackCurrent = extractSignal(data, 16, 16, false, true)\n  local value_PackCurrent = (raw_PackCurrent * 0.1) + 0\n  values[21] = value_PackCurrent\n\n  -- PackVoltage [V]\n  local raw_PackVoltage = extractSignal(data, 0, 16, false, false)\n  local value_PackVoltage = (raw_PackVoltage * 0.1) + 0\n  values[22] = value_PackVoltage\nend\n\n--\n-- Decodes CAN message: BMS_SOC_TEMP (ID: 0x401)\n--\n-- Signals (2):\n--   [23] StateOfCharge (%)\n--   [24] PackTemperature (degC)\n--\nlocal function decode_401(data)\n  -- StateOfCharge [%]\n  local raw_StateOfCharge = extractSignal(data, 0, 8, false, false)\n  local value_StateOfCharge = (raw_StateOfCharge * 1) + 0\n  values[23] = value_StateOfCharge\n\n  -- PackTemperature [degC]\n  local raw_PackTemperature = extractSignal(data, 8, 8, false, false)\n  local value_PackTemperature = (raw_PackTemperature * 1) + -40\n  values[24] = value_PackTemperature\nend\n\n--\n-- Decodes CAN message: BMS_CELL_VOLTAGES (ID: 0x402)\n--\n-- Signals (8):\n--   [25] Cell2Voltage (V)\n--   [26] Cell3Voltage (V)\n--   [27] Cell6Voltage (V)\n--   [28] Cell5Voltage (V)\n--   [29] Cell4Voltage (V)\n--   [30] Cell8Voltage (V)\n--   [31] Cell1Voltage (V)\n--   [32] Cell7Voltage (V)\n--\nlocal function decode_402(data)\n  -- Cell2Voltage [V]\n  local raw_Cell2Voltage = extractSignal(data, 8, 8, false, false)\n  local value_Cell2Voltage = (raw_Cell2Voltage * 0.00471) + 3\n  values[25] = value_Cell2Voltage\n\n  -- Cell3Voltage [V]\n  local raw_Cell3Voltage = extractSignal(data, 16, 8, false, false)\n  local value_Cell3Voltage = (raw_Cell3Voltage * 0.00471) + 3\n  values[26] = value_Cell3Voltage\n\n  -- Cell6Voltage [V]\n  local raw_Cell6Voltage = extractSignal(data, 40, 8, false, false)\n  local value_Cell6Voltage = (raw_Cell6Voltage * 0.00471) + 3\n  values[27] = value_Cell6Voltage\n\n  -- Cell5Voltage [V]\n  local raw_Cell5Voltage = extractSignal(data, 32, 8, false, false)\n  local value_Cell5Voltage = (raw_Cell5Voltage * 0.00471) + 3\n  values[28] = value_Cell5Voltage\n\n  -- Cell4Voltage [V]\n  local raw_Cell4Voltage = extractSignal(data, 24, 8, false, false)\n  local value_Cell4Voltage = (raw_Cell4Voltage * 0.00471) + 3\n  values[29] = value_Cell4Voltage\n\n  -- Cell8Voltage [V]\n  local raw_Cell8Voltage = extractSignal(data, 56, 8, false, false)\n  local value_Cell8Voltage = (raw_Cell8Voltage * 0.00471) + 3\n  values[30] = value_Cell8Voltage\n\n  -- Cell1Voltage [V]\n  local raw_Cell1Voltage = extractSignal(data, 0, 8, false, false)\n  local value_Cell1Voltage = (raw_Cell1Voltage * 0.00471) + 3\n  values[31] = value_Cell1Voltage\n\n  -- Cell7Voltage [V]\n  local raw_Cell7Voltage = extractSignal(data, 48, 8, false, false)\n  local value_Cell7Voltage = (raw_Cell7Voltage * 0.00471) + 3\n  values[32] = value_Cell7Voltage\nend\n\n--\n-- Decodes CAN message: CLUSTER_ODOMETER (ID: 0x500)\n--\n-- Signals (2):\n--   [33] Odometer (km)\n--   [34] TripDistance (km)\n--\nlocal function decode_500(data)\n  -- Odometer [km]\n  local raw_Odometer = extractSignal(data, 0, 32, false, false)\n  local value_Odometer = (raw_Odometer * 0.1) + 0\n  values[33] = value_Odometer\n\n  -- TripDistance [km]\n  local raw_TripDistance = extractSignal(data, 32, 16, false, false)\n  local value_TripDistance = (raw_TripDistance * 0.1) + 0\n  values[34] = value_TripDistance\nend\n\n--\n-- Decodes CAN message: CLUSTER_FUEL (ID: 0x501)\n--\n-- Signals (2):\n--   [35] FuelConsumption (L/100km)\n--   [36] FuelLevel (%)\n--\nlocal function decode_501(data)\n  -- FuelConsumption [L/100km]\n  local raw_FuelConsumption = extractSignal(data, 8, 16, false, false)\n  local value_FuelConsumption = (raw_FuelConsumption * 0.01) + 0\n  values[35] = value_FuelConsumption\n\n  -- FuelLevel [%]\n  local raw_FuelLevel = extractSignal(data, 0, 8, false, false)\n  local value_FuelLevel = (raw_FuelLevel * 1) + 0\n  values[36] = value_FuelLevel\nend\n\n--\n-- Decodes CAN message: ABS_WHEEL_SPEEDS (ID: 0x600)\n--\n-- Signals (4):\n--   [37] WheelSpeedFL (km/h)\n--   [38] WheelSpeedRR (km/h)\n--   [39] WheelSpeedRL (km/h)\n--   [40] WheelSpeedFR (km/h)\n--\nlocal function decode_600(data)\n  -- WheelSpeedFL [km/h]\n  local raw_WheelSpeedFL = extractSignal(data, 0, 16, false, false)\n  local value_WheelSpeedFL = (raw_WheelSpeedFL * 0.01) + 0\n  values[37] = value_WheelSpeedFL\n\n  -- WheelSpeedRR [km/h]\n  local raw_WheelSpeedRR = extractSignal(data, 48, 16, false, false)\n  local value_WheelSpeedRR = (raw_WheelSpeedRR * 0.01) + 0\n  values[38] = value_WheelSpeedRR\n\n  -- WheelSpeedRL [km/h]\n  local raw_WheelSpeedRL = extractSignal(data, 32, 16, false, false)\n  local value_WheelSpeedRL = (raw_WheelSpeedRL * 0.01) + 0\n  values[39] = value_WheelSpeedRL\n\n  -- WheelSpeedFR [km/h]\n  local raw_WheelSpeedFR = extractSignal(data, 16, 16, false, false)\n  local value_WheelSpeedFR = (raw_WheelSpeedFR * 0.01) + 0\n  values[40] = value_WheelSpeedFR\nend\n\n--\n-- Decodes CAN message: ABS_BRAKE_PRESSURE (ID: 0x601)\n--\n-- Signals (1):\n--   [41] BrakePressure (bar)\n--\nlocal function decode_601(data)\n  -- BrakePressure [bar]\n  local raw_BrakePressure = extractSignal(data, 0, 16, false, false)\n  local value_BrakePressure = (raw_BrakePressure * 0.1) + 0\n  values[41] = value_BrakePressure\nend\n\n--\n-- Decodes CAN message: STEERING_ANGLE (ID: 0x700)\n--\n-- Signals (1):\n--   [42] SteeringAngle (deg)\n--\nlocal function decode_700(data)\n  -- SteeringAngle [deg]\n  local raw_SteeringAngle = extractSignal(data, 0, 16, false, true)\n  local value_SteeringAngle = (raw_SteeringAngle * 0.1) + 0\n  values[42] = value_SteeringAngle\nend\n\nfunction parse(frame)\n  if #frame < 3 then return values end\n\n  local canId = (frame[1] << 8) | frame[2]\n  local dlc = frame[3]\n\n  -- Extract data payload (1-indexed)\n  local data = {}\n  for i = 1, dlc do\n    if 3 + i <= #frame then data[i] = frame[3 + i] end\n  end\n\n  -- Route CAN ID to the matching message decoder\n  if canId == 0x100 then\n    -- ENGINE_RPM_SPEED\n    decode_100(data)\n  elseif canId == 0x101 then\n    -- ENGINE_TEMP_LOAD\n    decode_101(data)\n  elseif canId == 0x102 then\n    -- ENGINE_THROTTLE\n    decode_102(data)\n  elseif canId == 0x200 then\n    -- TRANSMISSION_GEAR\n    decode_200(data)\n  elseif canId == 0x300 then\n    -- BCM_LIGHTS\n    decode_300(data)\n  elseif canId == 0x301 then\n    -- BCM_DOORS\n    decode_301(data)\n  elseif canId == 0x400 then\n    -- BMS_VOLTAGE_CURRENT\n    decode_400(data)\n  elseif canId == 0x401 then\n    -- BMS_SOC_TEMP\n    decode_401(data)\n  elseif canId == 0x402 then\n    -- BMS_CELL_VOLTAGES\n    decode_402(data)\n  elseif canId == 0x500 then\n    -- CLUSTER_ODOMETER\n    decode_500(data)\n  elseif canId == 0x501 then\n    -- CLUSTER_FUEL\n    decode_501(data)\n  elseif canId == 0x600 then\n    -- ABS_WHEEL_SPEEDS\n    decode_600(data)\n  elseif canId == 0x601 then\n    -- ABS_BRAKE_PRESSURE\n    decode_601(data)\n  elseif canId == 0x700 then\n    -- STEERING_ANGLE\n    decode_700(data)\n  end\n\n  return values\nend\n",
            "frameParserLanguage": 1,
            "frameStart": "",
            "hexadecimalDelimiters": false,
            "sourceId": 0,
            "title": "CAN Bus"
        }
