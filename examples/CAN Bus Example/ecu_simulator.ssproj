                    "title": "CurrentGear",
                    "transformCode": "local LABELS = {\n  [0] = \"Park/Neutral\",\n  [1] = \"1st\",\n  [2] = \"2nd\",\n  [3] = \"3rd\",\n  [4] = \"4th\",\n  [5] = \"5th\",\n  [6] = \"6th\",\n  [255] = \"Reverse\",\n}\n\nfunction transform(value)\n  local raw = math.floor((tableGet(\"TRANSMISSION_GEAR\", \"CurrentGear\") or 0) + 0.5)\n  return LABELS[raw] or (\"Unknown (\" .. raw .. \")\")\nend\n",
