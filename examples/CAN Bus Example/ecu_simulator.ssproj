    "hexadecimalDelimiters": false,
    "mqttPublisher": {
        "cleanSession": true,
        "customClientId": false,
        "enabled": false,
        "hostname": "127.0.0.1",
        "keepAlive": 60,
        "mode": 0,
        "mqttVersion": 2,
        "notificationTopic": "",
        "peerVerifyDepth": 10,
        "peerVerifyMode": 3,
        "port": 1883,
        "publishFrequency": 10,
        "publishNotifications": false,
        "scriptCode": "",
        "scriptLanguage": 0,
        "scriptTopic": "",
        "sslEnabled": false,
        "sslProtocol": 5,
        "topicBase": ""
    },
    "nextUniqueId": 140014,
    "plotTimeRange": 5,
    "pointCount": 4000,
    "schemaVersion": 3,
    "sources": [
        {
            "busType": 5,
            "checksum": "",
            "checksumAlgorithm": "",
            "connection": {
                "bitrate": 500000,
                "canFD": false,
                "deviceId": {
                    "interface": "can0",
                    "plugin": "virtualcan"
                },
                "interfaceIndex": 0,
                "listenOnly": false,
                "loopback": false,
                "pluginIndex": 3
            },
            "decoder": 3,
            "decoderMethod": 3,
            "frameDetection": 2,
            "frameEnd": "",
            "frameParserCode": "--[[\n  CAN frame parser generated by the Serial Studio DBC importer.\n  Source database: ecu_simulator.dbc\n\n  Wire format (Serial Studio CAN driver):\n    standard:  [ID_hi, ID_lo, DLC, data0..dataN]\n    extended:  [0x80|ID28..24, ID23..16, ID15..8, ID7..0, DLC, data0..dataN]\n    parse() receives these bytes as a 1-indexed Lua table (Binary decoder).\n\n  Data flow:\n    parse() decodes every known signal and publishes its physical value\n    with tableSet(\"<message>\", \"<signal>\", value); each dataset reads the\n    value back with tableGet() inside its transform, so datasets never\n    depend on positional parser channels.\n\n  To add a signal:\n    1. Add one line to MESSAGES below (bit layout from the DBC).\n    2. Add a register with the same name to the message's data table.\n    3. Add a dataset whose transform reads it back with tableGet().\n]]\n\n-- Signal layout fields (omitted fields use the defaults):\n--   start    DBC start bit               len     bit length\n--   be       true = Motorola (@0)        signed  true = two's complement\n--   factor   raw -> physical multiplier  offset  raw -> physical offset\n--   selector marks the multiplexor       mux     gates the entry on a selector value\nlocal MESSAGES = {\n  -- ENGINE_RPM_SPEED @ 0x100: Engine RPM and vehicle speed\n  [0x100] = {\n    table = \"ENGINE_RPM_SPEED\",\n    signals = {\n      { name = \"VehicleSpeed\", start = 16, len = 16, factor = 0.01 }, -- Vehicle speed in km/h\n      { name = \"EngineRPM\", start = 0, len = 16, factor = 0.25 }, -- Engine speed in RPM\n    },\n  },\n  -- ENGINE_TEMP_LOAD @ 0x101: Engine temperatures and load\n  [0x101] = {\n    table = \"ENGINE_TEMP_LOAD\",\n    signals = {\n      { name = \"EngineLoad\", start = 16, len = 8 }, -- Calculated engine load percentage\n      { name = \"CoolantTemp\", start = 0, len = 8, offset = -40 }, -- Engine coolant temperature\n      { name = \"IntakeTemp\", start = 8, len = 8, offset = -40 }, -- Intake air temperature\n    },\n  },\n  -- ENGINE_THROTTLE @ 0x102: Throttle position and fuel pressure\n  [0x102] = {\n    table = \"ENGINE_THROTTLE\",\n    signals = {\n      { name = \"ThrottlePosition\", start = 0, len = 8, factor = 0.392157 },\n      { name = \"FuelPressure\", start = 8, len = 16 },\n    },\n  },\n  -- TRANSMISSION_GEAR @ 0x200: Transmission gear and temperature\n  [0x200] = {\n    table = \"TRANSMISSION_GEAR\",\n    signals = {\n      { name = \"CurrentGear\", start = 0, len = 8 }, -- Current transmission gear (0=P/N, 1-6=Forward, 255=R)\n      { name = \"TorqueConverterSlip\", start = 16, len = 8 },\n      { name = \"TransmissionTemp\", start = 8, len = 8, offset = -40 },\n    },\n  },\n  -- BCM_LIGHTS @ 0x300: Lighting status\n  [0x300] = {\n    table = \"BCM_LIGHTS\",\n    signals = {\n      { name = \"Headlights\", start = 0, len = 1 },\n      { name = \"HighBeams\", start = 1, len = 1 },\n      { name = \"TurnSignalLeft\", start = 2, len = 1 },\n      { name = \"TurnSignalRight\", start = 3, len = 1 },\n      { name = \"HazardLights\", start = 4, len = 1 },\n    },\n  },\n  -- BCM_DOORS @ 0x301: Door status\n  [0x301] = {\n    table = \"BCM_DOORS\",\n    signals = {\n      { name = \"DoorFrontLeft\", start = 0, len = 1 },\n      { name = \"Trunk\", start = 4, len = 1 },\n      { name = \"DoorRearLeft\", start = 2, len = 1 },\n      { name = \"DoorFrontRight\", start = 1, len = 1 },\n      { name = \"DoorRearRight\", start = 3, len = 1 },\n    },\n  },\n  -- BMS_VOLTAGE_CURRENT @ 0x400: Battery pack voltage and current\n  [0x400] = {\n    table = \"BMS_VOLTAGE_CURRENT\",\n    signals = {\n      { name = \"PackVoltage\", start = 0, len = 16, factor = 0.1 },\n      { name = \"PackCurrent\", start = 16, len = 16, signed = true, factor = 0.1 },\n    },\n  },\n  -- BMS_SOC_TEMP @ 0x401: Battery state of charge and temperature\n  [0x401] = {\n    table = \"BMS_SOC_TEMP\",\n    signals = {\n      { name = \"PackTemperature\", start = 8, len = 8, offset = -40 },\n      { name = \"StateOfCharge\", start = 0, len = 8 },\n    },\n  },\n  -- BMS_CELL_VOLTAGES @ 0x402: Individual cell voltages (sample of 8 cells)\n  [0x402] = {\n    table = \"BMS_CELL_VOLTAGES\",\n    signals = {\n      { name = \"Cell8Voltage\", start = 56, len = 8, factor = 0.00471, offset = 3 },\n      { name = \"Cell7Voltage\", start = 48, len = 8, factor = 0.00471, offset = 3 },\n      { name = \"Cell3Voltage\", start = 16, len = 8, factor = 0.00471, offset = 3 },\n      { name = \"Cell5Voltage\", start = 32, len = 8, factor = 0.00471, offset = 3 },\n      { name = \"Cell2Voltage\", start = 8, len = 8, factor = 0.00471, offset = 3 },\n      { name = \"Cell4Voltage\", start = 24, len = 8, factor = 0.00471, offset = 3 },\n      { name = \"Cell6Voltage\", start = 40, len = 8, factor = 0.00471, offset = 3 },\n      { name = \"Cell1Voltage\", start = 0, len = 8, factor = 0.00471, offset = 3 },\n    },\n  },\n  -- CLUSTER_ODOMETER @ 0x500: Odometer and trip distance\n  [0x500] = {\n    table = \"CLUSTER_ODOMETER\",\n    signals = {\n      { name = \"Odometer\", start = 0, len = 32, factor = 0.1 },\n      { name = \"TripDistance\", start = 32, len = 16, factor = 0.1 },\n    },\n  },\n  -- CLUSTER_FUEL @ 0x501: Fuel level and consumption\n  [0x501] = {\n    table = \"CLUSTER_FUEL\",\n    signals = {\n      { name = \"FuelConsumption\", start = 8, len = 16, factor = 0.01 },\n      { name = \"FuelLevel\", start = 0, len = 8 },\n    },\n  },\n  -- ABS_WHEEL_SPEEDS @ 0x600: Individual wheel speeds\n  [0x600] = {\n    table = \"ABS_WHEEL_SPEEDS\",\n    signals = {\n      { name = \"WheelSpeedRL\", start = 32, len = 16, factor = 0.01 },\n      { name = \"WheelSpeedFR\", start = 16, len = 16, factor = 0.01 },\n      { name = \"WheelSpeedRR\", start = 48, len = 16, factor = 0.01 },\n      { name = \"WheelSpeedFL\", start = 0, len = 16, factor = 0.01 },\n    },\n  },\n  -- ABS_BRAKE_PRESSURE @ 0x601: Brake system pressure\n  [0x601] = {\n    table = \"ABS_BRAKE_PRESSURE\",\n    signals = {\n      { name = \"BrakePressure\", start = 0, len = 16, factor = 0.1 },\n    },\n  },\n  -- STEERING_ANGLE @ 0x700: Steering wheel angle\n  [0x700] = {\n    table = \"STEERING_ANGLE\",\n    signals = {\n      { name = \"SteeringAngle\", start = 0, len = 16, signed = true, factor = 0.1 },\n    },\n  },\n}\n\n-- Extracts one raw signal value; base is the 1-based index of the first\n-- payload byte. The Binary decoder hands parse() the frame as a 1-indexed\n-- table of byte values. Motorola (big-endian) walks the in-byte bit index\n-- down and jumps +15 across byte boundaries (the DBC sawtooth); Intel\n-- (little-endian) reads LSB-first runs. Bytes past the frame read 0.\nlocal function extract(frame, base, sig)\n  local value = 0\n  if sig.be then\n    local bit_pos = sig.start\n    for _ = 1, sig.len do\n      local byte = frame[base + (bit_pos // 8)] or 0\n      value = (value << 1) | ((byte >> (bit_pos % 8)) & 1)\n      bit_pos = (bit_pos % 8 == 0) and (bit_pos + 15) or (bit_pos - 1)\n    end\n  else\n    local bits_read = 0\n    local bit_shift = sig.start % 8\n    local byte_idx = sig.start // 8\n    while bits_read < sig.len do\n      local byte = frame[base + byte_idx] or 0\n      local take = math.min(8 - bit_shift, sig.len - bits_read)\n      value = value | (((byte >> bit_shift) & ((1 << take) - 1)) << bits_read)\n      bits_read = bits_read + take\n      bit_shift = 0\n      byte_idx = byte_idx + 1\n    end\n  end\n\n  if sig.signed and (value & (1 << (sig.len - 1))) ~= 0 then\n    value = value - (1 << sig.len)\n  end\n\n  return value\nend\n\n-- Returns the CAN id and the 1-based index of the first payload byte: bit 7\n-- of byte 1 selects the extended (29-bit, 4-byte id) header form.\nlocal function frame_id(frame)\n  local b1 = frame[1]\n  if (b1 & 0x80) ~= 0 then\n    if #frame < 5 then\n      return nil\n    end\n\n    local id = ((b1 & 0x1F) << 24) | (frame[2] << 16)\n             | (frame[3] << 8) | frame[4]\n    return id, 6\n  end\n\n  return ((b1 << 8) | frame[2]), 4\nend\n\nfunction parse(frame)\n  if #frame < 3 then\n    return {}\n  end\n\n  local id, base = frame_id(frame)\n  local msg = id and MESSAGES[id]\n  if not msg then\n    return {}\n  end\n\n  local selector = nil\n  for _, sig in ipairs(msg.signals) do\n    if sig.mux == nil or sig.mux == selector then\n      local raw = extract(frame, base, sig)\n      if sig.selector then\n        selector = raw\n      end\n\n      tableSet(msg.table, sig.name, raw * (sig.factor or 1) + (sig.offset or 0))\n    end\n  end\n\n  return { 0 } -- values flow through tableSet; datasets read them back\nend\n",
            "frameParserLanguage": 1,
            "frameStart": "",
            "hexadecimalDelimiters": false,
            "sourceId": 0,
            "title": "CAN Bus"
        }
    ],
