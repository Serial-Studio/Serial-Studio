            "frameParserCode": "/**\n * Testo T549i BLE frame parser (DecoderMethod = Binary).\n *\n * With the Binary decoder, parse(frame) receives a 0-indexed Array of byte\n * values (0-255), one BLE notification per call. The probe prefixes each\n * IEEE-754 little-endian float with an ASCII field name; we scan for the name\n * and read the 4 bytes that follow it. Notifications without a marker (CRC\n * and status frames) just re-emit the held values, so every dataset updates\n * on a steady timeline.\n *\n * Output order matches dataset index 1,2: [pressure Pa, battery %]. The\n * Pressure dataset's Lua transform converts Pa to psi for display.\n */\n\nvar pressurePa  = 0;\nvar battery     = 0;\n\nfunction indexOfMarker(frame, marker) {\n  for (var i = 0; i + marker.length <= frame.length; ++i) {\n    var hit = true;\n    for (var j = 0; j < marker.length; ++j) {\n      if (frame[i + j] !== marker.charCodeAt(j)) {\n        hit = false;\n        break;\n      }\n    }\n    \n    if (hit)\n      return i + marker.length;\n  }\n  \n  return -1;\n}\n\nfunction floatLE(frame, at) {\n  var view = new DataView(new ArrayBuffer(4));\n  for (var i = 0; i < 4; ++i)\n    view.setUint8(i, frame[at + i] & 0xff);\n    \n  return view.getFloat32(0, true);\n}\n\nfunction parse(frame) {\n  var p = indexOfMarker(frame, \"DifferentialPressure\");\n  if (p !== -1 && p + 4 <= frame.length)\n    pressurePa = floatLE(frame, p);\n\n  var b = indexOfMarker(frame, \"BatteryLevel\");\n  if (b !== -1 && b + 4 <= frame.length)\n    battery = floatLE(frame, b);\n\n  return [pressurePa, battery];\n}\n",
            "frameParserParams": {
