<?xml version="1.0" encoding="UTF-8"?>
<style-scheme version="1.0" name="Fluent Light">
  <!-- General Colors -->
  <style name="Text" foreground="#1F1F1F" background="#FFFFFF"/>
  <style name="Selection" background="#0078D4" foreground="#FFFFFF"/>
  <style name="LineNumber" foreground="#8A8A8A" background="#F9F9F9"/>
  <style name="CurrentLine" background="#F3F3F3"/>
  <style name="CurrentLineNumber" foreground="#0078D4" bold="true"/>
  <style name="Occurrences" background="#E6E6E6"/>
  <style name="SearchResult" background="#FFF4CE" foreground="#1F1F1F"/>

  <!-- Syntax Highlighting (Visual Studio palette) -->
  <style name="Keyword" foreground="#0000FF"/>
  <style name="Type" foreground="#2B91AF"/>
  <style name="Function" foreground="#1F9CD8"/>
  <style name="Macro" foreground="#8F08C4"/>
  <style name="String" foreground="#A31515"/>
  <style name="Number" foreground="#098658"/>
  <style name="Comment" foreground="#008000"/>
  <style name="Label" foreground="#68217A"/>
  <style name="Operator" foreground="#1F1F1F"/>
  <style name="Punctuation" foreground="#1F1F1F"/>
  <style name="Preprocessor" foreground="#808080"/>

  <!-- Braces and Matching -->
  <style name="Parentheses" background="#CCE8FF" foreground="#1F1F1F"/>
  <style name="ParenthesesMismatch" background="#C42B1C" foreground="#FFFFFF"/>

  <!-- Errors and Warnings -->
  <style name="Warning" underlineColor="#CA5010" underlineStyle="SingleUnderline"/>
  <style name="Error" underlineColor="#C42B1C" underlineStyle="SingleUnderline"/>
  <style name="DisabledCode" foreground="#B8B8B8" italic="true"/>

  <!-- Diff Highlighting -->
  <style name="AddedLine" foreground="#107C10"/>
  <style name="RemovedLine" foreground="#C42B1C"/>
  <style name="DiffContextLine" background="#F3F3F3"/>
  <style name="DiffSourceLine" background="#FFF4CE"/>
  <style name="DiffDestLine" background="#E5F3E5"/>
</style-scheme>
